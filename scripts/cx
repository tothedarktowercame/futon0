#!/usr/bin/env bash
set -euo pipefail
#
# cx — Codex REPL in the terminal.
#
# Starts codex-repl inside terminal Emacs, allocating a fresh codex-N
# agent for each terminal session. Resume works by seeding that fresh
# agent with an existing Codex session id.
#
# Usage:
#   cx                    # resume latest Codex session for this cwd
#   cx SESSION-ID         # resume specific session in a fresh codex-N lane
#   cx --new              # force a fresh codex-N lane with no prior session
#   cx new M-foo          # force a fresh lane clocked into M-foo
#   cx new E-foo          # force a fresh lane clocked into E-foo
#   cx headless --new     # open on the futon-ops/headless Emacs instead
#

agency_base="${FUTON3C_EVIDENCE_BASE:-http://localhost:${FUTON3C_PORT:-7070}}"
emacsclient_bin="${EMACSCLIENT_BIN:-emacsclient}"
script_real="$(readlink -f "${BASH_SOURCE[0]}")"
futon3c_root="${FUTON3C_ROOT:-$(cd "$(dirname "${script_real}")/../../futon3c" && pwd)}"
emacs_dir="${FUTON3C_EMACS_DIR:-${futon3c_root}/emacs}"
codex_sessions_root="${CODEX_SESSIONS_ROOT:-${HOME}/.codex/sessions}"
socket_lib="${futon3c_root}/scripts/emacs-socket-lib.sh"

if [[ -f "${socket_lib}" ]]; then
  # shellcheck source=/home/joe/code/futon3c/scripts/emacs-socket-lib.sh
  source "${socket_lib}"
fi

running_inside_emacs() {
  [[ -n "${INSIDE_EMACS:-}" || -n "${EMACS:-}" ]]
}

find_emacs_socket() {
  if declare -F futon_preferred_emacs_socket >/dev/null 2>&1; then
    futon_preferred_emacs_socket && return 0
  fi
  echo "No preferred Emacs daemon found. Starting one..." >&2
  if declare -F futon_start_preferred_emacs_daemon >/dev/null 2>&1; then
    futon_start_preferred_emacs_daemon && return 0
  fi
  return 1
}

json_escape() { sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' <<< "${1:-}"; }
elisp_escape() { sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' <<< "$1"; }

latest_session_id() {
  python3 - "$PWD" "${codex_sessions_root}" <<'PY'
import json
import os
import sys
from pathlib import Path

cwd = os.path.realpath(sys.argv[1])
root = Path(sys.argv[2]).expanduser()

if not root.exists():
    raise SystemExit(1)

files = sorted(
    (p for p in root.rglob("rollout-*.jsonl") if p.is_file()),
    key=lambda p: p.stat().st_mtime,
    reverse=True,
)

for path in files:
    try:
        with path.open("r", encoding="utf-8") as fh:
            first = fh.readline()
        if not first:
            continue
        entry = json.loads(first)
        payload = entry.get("payload") or {}
        sid = payload.get("id")
        meta_cwd = payload.get("cwd")
        if sid and meta_cwd and os.path.realpath(meta_cwd) == cwd:
            print(sid)
            raise SystemExit(0)
    except Exception:
        continue

raise SystemExit(1)
PY
}

build_auto_register_payload() {
  local working_directory="$1"
  local session_id="$2"
  local payload='{"type":"codex","cwd":"'"$(json_escape "${working_directory}")"'"'
  if [[ -n "${session_id}" ]]; then
    payload+=',"session-id":"'"$(json_escape "${session_id}")"'"'
  fi
  case "${clock_target:-}" in
    C-*) payload+=',"campaign-id":"'"$(json_escape "${clock_target}")"'"' ;;
    M-*) payload+=',"mission-id":"'"$(json_escape "${clock_target}")"'"' ;;
    E-*) payload+=',"excursion-id":"'"$(json_escape "${clock_target}")"'"' ;;
  esac
  payload+='}'
  printf '%s' "${payload}"
}

sid=""
start_new=false
headless=false
clock_target=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --new|new)
      start_new=true
      shift
      if [[ $# -gt 0 && "$1" != -* ]]; then
        clock_target="$1"
        shift
      fi
      ;;
    --headless|headless) headless=true; shift ;;
    --help|-h)
      echo "Usage: cx [SESSION-ID] [--new] [headless]"
      echo "  cx             resume latest Codex session for this cwd"
      echo "  cx SESSION-ID  resume specific session in a fresh codex lane"
      echo "  cx --new       start a fresh codex lane"
      echo "  cx new M-foo   start fresh clocked into M-foo"
      echo "  cx new E-foo   start fresh clocked into E-foo"
      echo "  cx headless    prefer futon-ops instead of the interactive server"
      exit 0
      ;;
    *) sid="$1"; shift ;;
  esac
done

if $headless; then
  export FUTON3C_EMACS_PREFERENCE=headless
else
  export FUTON3C_EMACS_PREFERENCE=interactive
fi

echo "--- cx debug ---"
echo "Agency:       ${agency_base}"
echo "Emacs dir:    ${emacs_dir}"
echo "Working dir:  $(pwd)"
echo "Mode:         $(if $start_new; then echo 'new session'; else echo 'resume'; fi)"
echo "Emacs pref:   $(if $headless; then echo 'headless'; else echo 'interactive'; fi)"
[[ -n "${clock_target}" ]] && echo "Clock target: ${clock_target}"

# --- Agency auto-start -------------------------------------------------------

agency_reachable() {
  curl -sS --max-time 2 "${agency_base}/api/alpha/agents" >/dev/null 2>&1
}

start_agency_via_emacs() {
  local sock="$1"
  local futon_root
  futon_root="$(cd "${futon3c_root}" && pwd)"
  local escaped_root
  escaped_root="$(elisp_escape "${futon_root}")"
  echo "Agency:       starting via Emacs *server* buffer..."
  "${emacsclient_bin}" -s "${sock}" -n --eval \
    "(let ((buf (get-buffer \"*server*\"))) (if (and buf (get-buffer-process buf) (process-live-p (get-buffer-process buf))) (message \"*server* already running\") (let ((buf (get-buffer-create \"*server*\"))) (with-current-buffer buf (let ((default-directory \"${escaped_root}/\")) (unless (derived-mode-p 'shell-mode) (make-comint-in-buffer \"server\" buf shell-file-name) (shell-mode)) (goto-char (point-max)) (insert \"./scripts/dev-laptop-env\") (comint-send-input))) \"started\")))" >/dev/null 2>&1
}

wait_for_agency() {
  local max_wait="${FUTON3C_AGENCY_TIMEOUT:-30}"
  local waited=0
  while (( waited < max_wait )); do
    if agency_reachable; then
      echo "Agency:       up after ${waited}s"
      return 0
    fi
    sleep 1
    (( waited++ ))
  done
  echo "Agency:       timed out after ${max_wait}s" >&2
  return 1
}

# Check Agency — auto-start if needed
if agency_reachable; then
  echo "Agency:       reachable"
else
  echo "Agency:       NOT reachable"
  _sock="$(find_emacs_socket 2>/dev/null)" || true
  if [[ -n "${_sock}" ]]; then
    start_agency_via_emacs "${_sock}"
    if ! wait_for_agency; then
      echo "Agency:       could not start — aborting" >&2
      exit 1
    fi
  else
    echo "Agency:       no Emacs socket found, cannot auto-start" >&2
    exit 1
  fi
fi

if $start_new; then
  echo "Action:       allocating fresh codex lane"
elif [[ -n "${sid}" ]]; then
  echo "Action:       resuming explicit session ${sid:0:8}..."
elif sid="$(latest_session_id 2>/dev/null || true)"; [[ -n "${sid}" ]]; then
  echo "Action:       found latest Codex session ${sid:0:8}... for $(pwd)"
else
  echo "Action:       no prior Codex session found; allocating fresh lane"
fi

echo "--- launching ---"

socket="$(find_emacs_socket)" || exit 1
echo "Emacs socket: ${socket}"

escaped_chat="$(elisp_escape "${emacs_dir}/agent-chat.el")"
escaped_repl="$(elisp_escape "${emacs_dir}/codex-repl.el")"
escaped_api="$(elisp_escape "${agency_base%/}")"
escaped_cwd="$(elisp_escape "$(pwd)")"
escaped_clock_target="$(elisp_escape "${clock_target}")"
payload="$(build_auto_register_payload "$(pwd)" "${sid}")"
fresh_session_elisp="nil"
if $start_new; then
  fresh_session_elisp="t"
fi

reg_result="$(curl -sS --max-time 5 \
  -H "Content-Type: application/json" \
  -X POST \
  -d "${payload}" \
  "${agency_base%/}/api/alpha/agents/auto" 2>&1)"
echo "Registration: ${reg_result}"

aid="$(echo "${reg_result}" | python3 -c "import json,sys; print((json.load(sys.stdin).get('agent-id') or ''))" 2>/dev/null || echo "")"
sf="$(echo "${reg_result}" | python3 -c "import json,sys; print((json.load(sys.stdin).get('session-file') or ''))" 2>/dev/null || echo "")"

if [[ -z "${aid}" ]]; then
  echo "Registration failed: could not parse agent-id from /agents/auto response" >&2
  exit 1
fi
if [[ -z "${sf}" ]]; then
  sf="/tmp/futon-codex-session-id-${aid}"
fi

echo "Agent:        ${aid}"
echo "Session file: ${sf}"
[[ -n "${sid}" ]] && echo "Session:      ${sid}"

# --- Inhabitation turn -------------------------------------------------------
# Send an initial turn so Codex establishes a real session immediately.
# Only when starting fresh (no existing session to resume).

if [[ -z "${sid}" ]]; then
  inhabit_prompt="Runtime surface contract:
- Current surface: emacs-codex-repl (agent ${aid}).
- Your response is shown in an Emacs REPL buffer.
- Joe is ready to work. Greet briefly and await instructions.
- Working directory: $(pwd)"

  bell_payload="$(cat <<BELL
{"agent-id":"$(json_escape "${aid}")","prompt":"$(json_escape "${inhabit_prompt}")","caller":"cx","surface":"emacs-codex-repl"}
BELL
)"
  bell_result="$(curl -sS --max-time 5 \
    -H "Content-Type: application/json" \
    -X POST -d "${bell_payload}" \
    "${agency_base%/}/api/alpha/bell" 2>&1)"
  echo "Inhabitation: ${bell_result}"
fi

# Always switch to the REPL buffer after init — needed both for
# inside-Emacs and external shell launches.
switch_form="(switch-to-buffer (format \"*codex-repl:%s*\" \"${aid}\"))"

codex_repl_eval="$(cat <<EOF
(progn
    (add-to-list 'load-path "${emacs_dir}")
    (load "${escaped_chat}" nil t)
    (load "${escaped_repl}" nil t)
    (codex-repl--open-instance
     (format "*codex-repl:%s*" "${aid}")
     (format "*invoke: codex-repl:%s*" "${aid}")
     "${escaped_api}"
     "${aid}"
     "$(elisp_escape "${sf}")"
     "${escaped_cwd}"
     'attached
     ${fresh_session_elisp}
     (unless (string-empty-p "${escaped_clock_target}")
       "${escaped_clock_target}"))
    ${switch_form})
EOF
)"

if running_inside_emacs; then
  "${emacsclient_bin}" -s "${socket}" -n --eval "${codex_repl_eval}" 2>&1 || true
  exit 0
fi

# Do not use `-t` here. `emacsclient -t --eval` evaluates inside a transient
# terminal client frame, prints the returned buffer object, then exits, leaving
# the REPL buffer undisplayed in the user's live Emacs frame.
exec "${emacsclient_bin}" -s "${socket}" -n \
  --eval "${codex_repl_eval}" >/dev/null
