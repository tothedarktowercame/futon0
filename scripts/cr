#!/usr/bin/env bash
set -euo pipefail
#
# cr — Claude REPL in the terminal.
#
# Starts claude-repl inside terminal Emacs (emacsclient -t), with
# evidence logging, frame persistence, and session continuity.
# Same friction as: alacritty -e claude --permission-mode bypassPermissions
#
# Usage:
#   cr                    # resume latest session (or start new)
#   cr SESSION-ID         # resume specific session
#   cr --new              # force new session
#   cr new M-foo          # force new session clocked into M-foo
#
# Requires: Emacs daemon running, Agency (futon3c) on port 7070.
#
# This script exists because surface-earns-inhabitation.flexiarg:
# if the infrastructure path is harder to enter than the primitive
# path, the primitive path wins and the Baldwin loop starves.

evidence_base="${FUTON3C_EVIDENCE_BASE:-http://localhost:${FUTON3C_PORT:-7070}}"
session_file="${CLAUDE_SESSION_FILE:-/tmp/futon-session-id}"
emacsclient_bin="${EMACSCLIENT_BIN:-emacsclient}"
script_real="$(readlink -f "${BASH_SOURCE[0]}")"
futon3c_root="${FUTON3C_ROOT:-${HOME}/code/futon3c}"
emacs_dir="${FUTON3C_EMACS_DIR:-$(cd "$(dirname "${script_real}")/../../futon3c/emacs" && pwd)}"
claude_sessions_root="${CLAUDE_SESSIONS_ROOT:-${HOME}/.claude/sessions}"
claude_projects_root="${CLAUDE_PROJECTS_ROOT:-${HOME}/.claude/projects}"
socket_lib="${futon3c_root}/scripts/emacs-socket-lib.sh"

if [[ -f "${socket_lib}" ]]; then
  # shellcheck source=/home/joe/code/futon3c/scripts/emacs-socket-lib.sh
  source "${socket_lib}"
fi

running_inside_emacs() {
  [[ -n "${INSIDE_EMACS:-}" || -n "${EMACS:-}" ]]
}

# --- Socket discovery --------------------------------------------------------

find_emacs_socket() {
  if declare -F futon_preferred_emacs_socket >/dev/null 2>&1; then
    futon_preferred_emacs_socket && return 0
  fi
  echo "No preferred Emacs daemon found. Starting one..." >&2
  if declare -F futon_start_preferred_emacs_daemon >/dev/null 2>&1; then
    futon_start_preferred_emacs_daemon && return 0
  fi
  return 1
}

# --- Session handling --------------------------------------------------------

json_escape() { sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' <<< "${1:-}"; }
elisp_escape() { sed -e 's/\\/\\\\/g' -e 's/"/\\"/g' <<< "$1"; }

emit_evidence() {
  local sid="$1"
  [[ -n "${sid}" ]] || return 0
  command -v curl >/dev/null 2>&1 || return 0
  local payload
  payload="$(cat <<EOF
{"subject":{"ref/type":"session","ref/id":"$(json_escape "${sid}")"},"type":"coordination","claim-type":"goal","author":"$(json_escape "${USER:-joe}")","session-id":"$(json_escape "${sid}")","body":{"event":"session-start","source":"cr","mode":"terminal-repl","cwd":"$(json_escape "$(pwd)")"},"tags":["claude","session-start","cr"]}
EOF
)"
  curl -sS --max-time 1 \
    -H "Content-Type: application/json" \
    -X POST -d "${payload}" \
    "${evidence_base%/}/api/alpha/evidence" >/dev/null 2>&1 || true
}

latest_session_id() {
  python3 - "$PWD" "${claude_sessions_root}" "${claude_projects_root}" <<'PY'
import json
import os
import sys
from pathlib import Path

cwd = os.path.realpath(sys.argv[1])
sessions_root = Path(os.path.expanduser(sys.argv[2]))
projects_root = Path(os.path.expanduser(sys.argv[3]))

def from_sessions():
    if not sessions_root.exists():
        return None
    files = sorted(sessions_root.glob("*.json"),
                   key=lambda p: p.stat().st_mtime,
                   reverse=True)
    for path in files:
        try:
            data = json.loads(path.read_text())
        except Exception:
            continue
        sid = data.get("sessionId")
        scwd = data.get("cwd")
        if sid and scwd and os.path.realpath(scwd) == cwd:
            return sid
    return None

def from_projects():
    encoded = cwd.replace("/", "-")
    target = projects_root / encoded
    if not target.exists():
        return None
    index = target / "sessions-index.json"
    if index.exists():
        try:
            entries = json.loads(index.read_text()).get("entries") or []
        except Exception:
            entries = []
        entries = sorted(entries,
                         key=lambda e: e.get("modified") or e.get("created") or "",
                         reverse=True)
        for entry in entries:
            sid = entry.get("sessionId")
            if sid:
                return sid
    jsonl_files = sorted(target.glob("*.jsonl"),
                         key=lambda p: p.stat().st_mtime,
                         reverse=True)
    for path in jsonl_files:
        stem = path.stem
        if stem:
            return stem
    return None

sid = from_sessions() or from_projects()
if sid:
    print(sid.strip())
    raise SystemExit(0)
raise SystemExit(1)
PY
}

build_auto_register_payload() {
  local socket_name="$1"
  local session_id="$2"
  local payload='{"type":"claude","cwd":"'"$(json_escape "$(pwd)")"'"'
  if [[ -n "${socket_name}" ]]; then
    payload+=',"emacs-socket":"'"$(json_escape "${socket_name}")"'"'
  fi
  if [[ -n "${session_id}" ]]; then
    payload+=',"session-id":"'"$(json_escape "${session_id}")"'"'
  fi
  case "${clock_target:-}" in
    C-*) payload+=',"campaign-id":"'"$(json_escape "${clock_target}")"'"' ;;
    M-*) payload+=',"mission-id":"'"$(json_escape "${clock_target}")"'"' ;;
  esac
  payload+='}'
  printf '%s' "${payload}"
}

build_restore_payload() {
  local agent_id="$1"
  local socket_name="$2"
  local session_id="$3"
  local session_file="$4"
  local payload='{"agent-id":"'"$(json_escape "${agent_id}")"'","type":"claude","cwd":"'"$(json_escape "$(pwd)")"'"'
  if [[ -n "${socket_name}" ]]; then
    payload+=',"emacs-socket":"'"$(json_escape "${socket_name}")"'"'
  fi
  if [[ -n "${session_id}" ]]; then
    payload+=',"session-id":"'"$(json_escape "${session_id}")"'"'
  fi
  if [[ -n "${session_file}" ]]; then
    payload+=',"session-file":"'"$(json_escape "${session_file}")"'"'
  fi
  case "${clock_target:-}" in
    C-*) payload+=',"campaign-id":"'"$(json_escape "${clock_target}")"'"' ;;
    M-*) payload+=',"mission-id":"'"$(json_escape "${clock_target}")"'"' ;;
  esac
  payload+='}'
  printf '%s' "${payload}"
}

find_live_claude_agents_for_session() {
  local sid="$1"
  [[ -n "${sid}" ]] || return 0
  curl -sS --max-time 5 "${evidence_base%/}/api/alpha/agents" 2>/dev/null | \
    python3 - "$sid" <<'PY'
import json
import re
import sys

sid = sys.argv[1]
try:
    payload = json.load(sys.stdin)
except Exception:
    raise SystemExit(0)

agents = payload.get("agents") or {}
matches = []
for agent_id, info in agents.items():
    if not isinstance(info, dict):
        continue
    if info.get("type") != "claude":
        continue
    if info.get("session-id") != sid:
        continue
    metadata = info.get("metadata") or {}
    if metadata.get("proxy?") or metadata.get("remote?"):
        continue
    matches.append(agent_id)

def sort_key(agent_id: str):
    m = re.match(r"^claude-(\d+)$", agent_id)
    return (0, int(m.group(1))) if m else (1, agent_id)

for agent_id in sorted(matches, key=sort_key):
    print(agent_id)
PY
}

find_attached_buffer_for_session() {
  local socket_name="$1"
  local sid="$2"
  [[ -n "${sid}" ]] || return 0
  find_attached_buffer_common "${socket_name}" "claude-repl-find-buffer-by-session-id" "${sid}"
}

find_attached_buffer_for_agent() {
  local socket_name="$1"
  local agent_id="$2"
  [[ -n "${agent_id}" ]] || return 0
  find_attached_buffer_common "${socket_name}" "claude-repl-find-buffer-by-agent-id" "${agent_id}"
}

find_attached_buffer_common() {
  local socket_name="$1"
  local finder_fn="$2"
  local needle="$3"
  [[ -n "${needle}" ]] || return 0
  local escaped_chat escaped_repl escaped_sid
  escaped_chat="$(elisp_escape "${emacs_dir}/agent-chat.el")"
  escaped_repl="$(elisp_escape "${emacs_dir}/claude-repl.el")"
  escaped_sid="$(elisp_escape "${needle}")"
  "${emacsclient_bin}" -s "${socket_name}" --eval \
    "(progn
       (setq load-prefer-newer t)
       (add-to-list 'load-path \"${emacs_dir}\")
       (load \"${escaped_chat}\" nil t)
       (load \"${escaped_repl}\" nil t)
       (when-let ((buf (${finder_fn} \"${escaped_sid}\")))
         (buffer-name buf)))" 2>/dev/null | tr -d '"'
}

switch_to_buffer() {
  local socket_name="$1"
  local buffer_name="$2"
  local escaped_buffer
  escaped_buffer="$(elisp_escape "${buffer_name}")"
  if running_inside_emacs; then
    "${emacsclient_bin}" -s "${socket_name}" -n --eval \
      "(pop-to-buffer \"${escaped_buffer}\")" >/dev/null 2>&1 || true
    exit 0
  fi
  exec "${emacsclient_bin}" -s "${socket_name}" -t --eval \
    "(pop-to-buffer \"${escaped_buffer}\")"
}

# --- Args --------------------------------------------------------------------

sid=""
start_new=false
clock_target=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --new|new)
      start_new=true
      shift
      if [[ $# -gt 0 && "$1" != -* ]]; then
        clock_target="$1"
        shift
      fi
      ;;
    --help|-h)
      echo "Usage: cr [SESSION-ID] [--new [C-foo|M-foo]]"
      echo "  cr             resume latest session"
      echo "  cr SESSION-ID  resume specific session"
      echo "  cr --new       start fresh"
      echo "  cr new M-foo   start fresh clocked into M-foo"
      exit 0
      ;;
    *) sid="$1"; shift ;;
  esac
done

# --- Resolve session ---------------------------------------------------------

echo "--- cr debug ---"
echo "Agency:       ${evidence_base}"
echo "Emacs dir:    ${emacs_dir}"
echo "Mode:         $(if $start_new; then echo 'new session'; else echo 'resume'; fi)"
[[ -n "${clock_target}" ]] && echo "Clock target: ${clock_target}"

# --- Agency auto-start -------------------------------------------------------

agency_reachable() {
  curl -sS --max-time 2 "${evidence_base}/api/alpha/agents" >/dev/null 2>&1
}

start_agency_via_emacs() {
  local sock="$1"
  local futon_root
  futon_root="$(cd "$(dirname "${script_real}")/../../futon3c" && pwd)"
  local escaped_root
  escaped_root="$(elisp_escape "${futon_root}")"
  echo "Agency:       starting via Emacs *server* buffer..."
  "${emacsclient_bin}" -s "${sock}" -n --eval \
    "(let ((buf (get-buffer \"*server*\"))) (if (and buf (get-buffer-process buf) (process-live-p (get-buffer-process buf))) (message \"*server* already running\") (let ((buf (get-buffer-create \"*server*\"))) (with-current-buffer buf (let ((default-directory \"${escaped_root}/\")) (unless (derived-mode-p 'shell-mode) (make-comint-in-buffer \"server\" buf shell-file-name) (shell-mode)) (goto-char (point-max)) (insert \"./scripts/dev-laptop-env\") (comint-send-input))) \"started\")))" >/dev/null 2>&1
}

wait_for_agency() {
  local max_wait="${FUTON3C_AGENCY_TIMEOUT:-30}"
  local waited=0
  while (( waited < max_wait )); do
    if agency_reachable; then
      echo "Agency:       up after ${waited}s"
      return 0
    fi
    sleep 1
    (( waited++ ))
  done
  echo "Agency:       timed out after ${max_wait}s" >&2
  return 1
}

# Check Agency — auto-start if needed
if agency_reachable; then
  echo "Agency:       reachable"
else
  echo "Agency:       NOT reachable"
  # Need Emacs socket early for auto-start
  _sock="$(find_emacs_socket 2>/dev/null)" || true
  if [[ -n "${_sock}" ]]; then
    start_agency_via_emacs "${_sock}"
    if ! wait_for_agency; then
      echo "Agency:       could not start — continuing without registration" >&2
    fi
  else
    echo "Agency:       no Emacs socket found, cannot auto-start" >&2
  fi
fi

# Show existing session file state
echo "Session files:"
for f in "${session_file}" /tmp/futon-session-id-claude-*; do
  if [[ -f "$f" ]]; then
    echo "  $f = $(cat "$f")"
  fi
done

if $start_new; then
  sid=""
  echo "Action:       forcing a fresh claude lane (session hints left intact)"
elif [[ -n "${sid}" ]]; then
  echo "Action:       will resume explicit session ${sid:0:8}..."
  emit_evidence "${sid}"
elif sid="$(latest_session_id 2>/dev/null || true)"; [[ -n "${sid}" ]]; then
  echo "Action:       found latest session ${sid:0:8}... for $(pwd)"
  emit_evidence "${sid}"
else
  echo "Action:       no prior session found; starting fresh"
fi

echo "--- launching ---"

# --- Launch ------------------------------------------------------------------

socket="$(find_emacs_socket)" || exit 1
echo "Emacs socket: ${socket}"

escaped_chat="$(elisp_escape "${emacs_dir}/agent-chat.el")"
escaped_repl="$(elisp_escape "${emacs_dir}/claude-repl.el")"
escaped_clock_target="$(elisp_escape "${clock_target}")"
cr_start_new_elisp="nil"
if $start_new; then
  cr_start_new_elisp="t"
fi

emacs_socket="${FUTON3C_EMACS_SOCKET:-$(${emacsclient_bin} -s "${socket}" -e '(or (and (boundp (quote server-name)) server-name) "server")' 2>/dev/null | tr -d '"')}"

aid=""
restore_mode=false
if [[ -n "${sid}" ]]; then
  mapfile -t live_agents < <(find_live_claude_agents_for_session "${sid}")
  if (( ${#live_agents[@]} > 0 )); then
    aid="${live_agents[0]}"
    restore_mode=true
    if (( ${#live_agents[@]} > 1 )); then
      echo "Warning:      multiple live Claude lanes claim ${sid:0:8}... -> ${live_agents[*]}"
    fi
    echo "Action:       reusing live Claude lane ${aid} for session ${sid:0:8}..."
    attached_buf="$(find_attached_buffer_for_agent "${socket}" "${aid}")"
    if [[ -n "${attached_buf}" && "${attached_buf}" != "nil" ]]; then
      echo "Action:       lane ${aid} already attached in ${attached_buf}"
      switch_to_buffer "${socket}" "${attached_buf}"
    fi
  fi
fi

if [[ -n "${sid}" && -z "${aid}" ]]; then
  attached_buf="$(find_attached_buffer_for_session "${socket}" "${sid}")"
  if [[ -n "${attached_buf}" && "${attached_buf}" != "nil" ]]; then
    echo "Action:       session already attached in ${attached_buf}"
    switch_to_buffer "${socket}" "${attached_buf}"
  fi
fi

if $restore_mode; then
  sf="/tmp/futon-session-id-${aid}"
  payload="$(build_restore_payload "${aid}" "${emacs_socket}" "${sid}" "${sf}")"
  reg_result=$(curl -sS --max-time 5 \
    -H "Content-Type: application/json" \
    -X POST \
    -d "${payload}" \
    "${evidence_base%/}/api/alpha/agents/restore" 2>&1)
  echo "Restore:      ${reg_result}"
else
  payload="$(build_auto_register_payload "${emacs_socket}" "${sid}")"
  reg_result=$(curl -sS --max-time 5 \
    -H "Content-Type: application/json" \
    -X POST \
    -d "${payload}" \
    "${evidence_base%/}/api/alpha/agents/auto" 2>&1)
  echo "Registration: ${reg_result}"
fi

aid="$(echo "${reg_result}" | python3 -c "import sys,json; print(json.load(sys.stdin).get('agent-id',''))" 2>/dev/null || echo "")"
if [[ -z "${aid}" ]]; then
  if $restore_mode; then
    echo "Restore failed: could not parse agent-id from /agents/restore response" >&2
  else
    echo "Registration failed: could not parse agent-id from /agents/auto response" >&2
  fi
  exit 1
fi

sf="/tmp/futon-session-id-${aid}"
if [[ -n "${sid}" ]]; then
  printf '%s' "${sid}" > "${sf}"
fi

echo "Agent:        ${aid}"
echo "Session file: ${sf}"
[[ -n "${sid}" ]] && echo "Session:      ${sid}"

# --- Inhabitation turn -------------------------------------------------------
# Send an initial turn so Claude establishes a real session immediately.
# Only when starting fresh (no existing session to resume).

if [[ -z "${sid}" ]]; then
  inhabit_prompt="Runtime surface contract:
- Current surface: emacs-claude-repl (agent ${aid}).
- Your response is shown in an Emacs REPL buffer.
- Joe is ready to work. Greet briefly and await instructions.
- Working directory: $(pwd)"

  bell_payload="$(cat <<BELL
{"agent-id":"$(json_escape "${aid}")","prompt":"$(json_escape "${inhabit_prompt}")","caller":"cr","surface":"emacs-claude-repl"}
BELL
)"
  bell_result="$(curl -sS --max-time 5 \
    -H "Content-Type: application/json" \
    -X POST -d "${bell_payload}" \
    "${evidence_base%/}/api/alpha/bell" 2>&1)"
  echo "Inhabitation: ${bell_result}"
fi

# Always switch to the REPL buffer after init — needed both for
# inside-Emacs (current window) and terminal frame (-t) cases.
switch_form="(switch-to-buffer buf)"

claude_repl_eval="$(cat <<EOF
(progn
    (setq load-prefer-newer t)
    (add-to-list 'load-path "${emacs_dir}")
    (load "${escaped_chat}" nil t)
    (load "${escaped_repl}" nil t)
    (let* ((aid "${aid}")
           (cr-sid "${sid}")
           (cr-start-new ${cr_start_new_elisp})
           (clock-target "${escaped_clock_target}")
           (bufname (format "*claude-repl:%s*" aid))
           (sf "${sf}")
           (api-url (string-remove-suffix "/" agent-chat-agency-base-url))
           (buf (get-buffer-create bufname)))
      (with-current-buffer buf
        (unless (eq major-mode 'claude-repl-mode) (claude-repl-mode))
        (setq-local claude-repl--workspace-applied t)
        (setq-local claude-repl-agent-id aid)
        (setq-local claude-repl-api-url api-url)
        (setq-local claude-repl-evidence-url (concat api-url "/api/alpha/evidence"))
        (setq-local claude-repl-session-file sf)
        (when cr-start-new
          (setq agent-chat--session-id nil)
          (setq agent-chat--session-turn-count 0)
          (when (file-exists-p sf)
            (delete-file sf))))
      (claude-repl--open-instance
       bufname agent-chat-agency-base-url aid sf
       (unless (string-empty-p clock-target) clock-target))
      (with-current-buffer buf
        (claude-repl--init-display)
        (unless (string-empty-p cr-sid)
          (agent-chat-update-session-id cr-sid)))
      ${switch_form}
      buf))
EOF
)"

if running_inside_emacs; then
  "${emacsclient_bin}" -s "${socket}" -n --eval "${claude_repl_eval}" 2>&1 || true
  exit 0
fi

exec "${emacsclient_bin}" -s "${socket}" -t --eval "${claude_repl_eval}"
